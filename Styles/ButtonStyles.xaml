    <ControlTemplate x:Key="md.sys.RadioButton.ControlTemplate" TargetType="RadioButton">
        <Grid x:Name="RootGrid" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{TemplateBinding Height}"/>
