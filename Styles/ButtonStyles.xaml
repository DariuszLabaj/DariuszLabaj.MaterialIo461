<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:converters="clr-namespace:DariuszLabaj.MaterialIo461.Converters"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ========================================================= -->
    <!-- Button Elevated -->
    <!-- ========================================================= -->

    <ControlTemplate x:Key="md.sys.Button.ControlTemplate-elevated" TargetType="Button">
        <Border x:Name="MainBorder" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
            Background="{TemplateBinding Background}" Margin="4"
            CornerRadius="{Binding Path=ActualHeight, RelativeSource={RelativeSource Self}, Converter={converters:ScaleConverter 0.5}}"
            SnapsToDevicePixels="True" UseLayoutRounding="True" CacheMode="BitmapCache"
            BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Opacity="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="325" ShadowDepth="2.5" Opacity="0.5"/>
            </Border.Effect>
            <Border  x:Name="SubBorder" 
                 Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" 
                 CornerRadius="{Binding Path=ActualHeight, RelativeSource={RelativeSource Self}, Converter={converters:ScaleConverter 0.5}}" 
                 Background="#00FFFFFF">
                <StackPanel Orientation="Horizontal" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="8 4">
                    <ContentControl Content="{TemplateBinding Tag}" Height="{TemplateBinding FontSize}" Margin="0 0 4 0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <ContentPresenter Content="{TemplateBinding Content}" Opacity="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ContentPresenter.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </ContentPresenter.Resources>
                    </ContentPresenter>
                </StackPanel>
            </Border>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="SubBorder" Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#20000000"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="MainBorder" Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black" Direction="325" ShadowDepth="1.5" Opacity="0.5"/>
                    </Setter.Value>
                </Setter>
                <Setter TargetName="SubBorder" Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#40000000"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="MainBorder" Property="Opacity" Value="0.5"/>
                <Setter TargetName="MainBorder" Property="Background" Value="{DynamicResource 50Brush}"/>
                <Setter TargetName="MainBorder" Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black" Direction="325" ShadowDepth="0" Opacity="0.5"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

