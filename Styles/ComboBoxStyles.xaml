<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:DariuszLabaj.MaterialIo461.Converters">
    <ControlTemplate x:Key="md.sys.ComboBox.ControlTemplate" TargetType="ComboBox">
        <Grid>
            <Border x:Name="Border"
                      CornerRadius="8"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="2"
                      Padding="4 0 0 0"
                      Height="{TemplateBinding FontSize, Converter={conv:ScaleConverter 2}}"
                      Background="{TemplateBinding Background}">
                <Grid VerticalAlignment="Center" Background="Transparent">
                    <Border x:Name="StateLayer" Background="{DynamicResource 80Brush}" CornerRadius="8" Opacity="0"/>
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter x:Name="ContentPresenter"
                                          Grid.Column="0"
                                          Margin="2 0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}">
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="{Binding FontFamily, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                    <Setter Property="FontSize" Value="{Binding FontSize, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                    <Setter Property="FontStretch" Value="{Binding FontStretch, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                    <Setter Property="FontStyle" Value="{Binding FontStyle, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                    <Setter Property="FontWeight" Value="{Binding FontWeight, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                    <Setter Property="Foreground" Value="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                        <ToggleButton x:Name="ToggleButton"
                                      Grid.Column="1"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Viewbox HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="960" Height="960" Background="Transparent">
                                            <Path Stroke="Black" StrokeThickness="1" Fill="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}" Data="M464-376 306-533q-2-2-3.5-4.76-1.5-2.77-1.5-5.92 0-6.32 4.13-10.82 4.12-4.5 10.87-4.5h328q6.75 0 10.88 4.64 4.12 4.63 4.12 10.81 0 1.55-5 10.55L496-376q-3 3-7.06 5t-8.94 2q-4.87 0-8.94-2-4.06-2-7.06-5Z">
                                                <Path.RenderTransform>
                                                    <TransformGroup>
                                                        <TranslateTransform X="-0" Y="960" />
                                                    </TransformGroup>
                                                </Path.RenderTransform>
                                            </Path>
                                        </Canvas>
                                    </Viewbox>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </Grid>
                </Grid>
            </Border>
            <Popup x:Name="Popup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=Border}"
                   MinWidth="{Binding ActualWidth, ElementName=Border}"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   AllowsTransparency="True"
                   Focusable="False"
                   PopupAnimation="Slide">
                <Grid>
                    <Border x:Name="DropDownBorder"
                            Background="{TemplateBinding Background}"
                            BorderThickness="2 0 2 2"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="0,0,4,4"/>
                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <!-- Hover -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="StateLayer" Property="Opacity" Value="0.08"/>
            </Trigger>
            <!-- Focus -->
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="Border" Property="BorderBrush" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
            </Trigger>
            <!-- Open -->
            <Trigger Property="IsDropDownOpen" Value="True">
                <Setter TargetName="Border" Property="BorderBrush" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
            </Trigger>
            <!-- Disabled -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.38"/>
                <Setter TargetName="StateLayer" Property="Opacity" Value="0"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="md.sys.ComboBoxItem.ControlTemplate" TargetType="ComboBoxItem">
        <Border x:Name="Border" CornerRadius="4" Background="Transparent" Margin="2">
            <ContentPresenter x:Name="ContentPresenter" Margin="4 2" Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                              ContentStringFormat="{TemplateBinding ContentStringFormat}"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Cursor="Hand">
                <ContentPresenter.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="{Binding FontFamily, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                        <Setter Property="FontSize" Value="{Binding FontSize, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                        <Setter Property="FontStretch" Value="{Binding FontStretch, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                        <Setter Property="FontStyle" Value="{Binding FontStyle, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                        <Setter Property="FontWeight" Value="{Binding FontWeight, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBoxItem}}"/>
                    </Style>
                </ContentPresenter.Resources>
            </ContentPresenter>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                <Setter Property="Foreground" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                <Setter Property="Foreground" Value="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="md.comboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Foreground" Value="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
        <Setter Property="Template" Value="{StaticResource md.sys.ComboBoxItem.ControlTemplate}"/>
    </Style>
    <Style x:Key="md.comboBox" TargetType="ComboBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template" Value="{StaticResource md.sys.ComboBox.ControlTemplate}"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource md.comboBoxItem}"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FontFamily" Value="{DynamicResource md.ref.typeface.plain}"/>
        <Setter Property="FontSize" Value="{DynamicResource md.sys.typescale.label-medium-size}"/>
        <Setter Property="Background" Value="{DynamicResource surfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource primaryFixedDimBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource primaryBrush}"/>
        <Setter Property="Margin" Value="4"/>
    </Style>
</ResourceDictionary>