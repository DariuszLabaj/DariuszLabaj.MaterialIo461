    <!-- TextBox -->
    <SolidColorBrush x:Key="md.sys.highlightBrush" Color="{DynamicResource primaryFixed}"/>
    
    <ControlTemplate x:Key="md.sys.TextBox.ControlTemplate" TargetType="{x:Type TextBoxBase}">
        <ControlTemplate.Resources>
            <converters:ThicknessToHeightConverter x:Key="ThicknessToHeightConverter"/>
        </ControlTemplate.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border x:Name="border" CornerRadius="4 4 0 0" Background="{TemplateBinding Background}" BorderThickness="0" SnapsToDevicePixels="True">
                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
            </Border>
            <Rectangle VerticalAlignment="Bottom" Height="{TemplateBinding BorderThickness ,Converter={StaticResource ThicknessToHeightConverter}}" Fill="{TemplateBinding BorderBrush}"/>
            <TextBlock x:Name="SupportingText" Visibility="Visible" Grid.Row="1" Text="{TemplateBinding Tag}" FontFamily="{TemplateBinding FontFamily}" FontSize="4" Height="Auto"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="false">
                <Setter Property="Opacity" TargetName="border" Value="0.56"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="true">
                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource md.sys.highlightBrush}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="true">
                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource md.sys.highlightBrush}"/>
            </Trigger>
            <Trigger Property="Tag" Value="{x:Null}">
                <Setter TargetName="SupportingText" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsInactiveSelectionHighlightEnabled" Value="true"/>
                    <Condition Property="IsSelectionActive" Value="false"/>
                </MultiTrigger.Conditions>
                <Setter Property="SelectionBrush" Value="{DynamicResource {x:Static SystemColors.InactiveSelectionHighlightBrushKey}}"/>
            </MultiTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

