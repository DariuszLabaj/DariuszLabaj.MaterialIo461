<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:cnv="clr-namespace:DariuszLabaj.MaterialIo461.Converters">
    <ControlTemplate TargetType="TabControl" x:Key="md.sys.TabControl.ControlTemplate.Elevated">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TopRow" Height="Auto"/>
                <RowDefinition x:Name="BottomRow" Height="*"/>
            </Grid.RowDefinitions>
            <TabPanel x:Name="HeaderPanel" Grid.Row="0" Margin="4" IsItemsHost="True" Panel.ZIndex="1" HorizontalAlignment="Center">
                <TabPanel.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" Opacity="1" ShadowDepth="1"/>
                </TabPanel.Effect>
            </TabPanel>
            <Border x:Name="ContentPanel" Grid.Row="1" Style="{DynamicResource ElevatedCard}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}">
                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}"/>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="TabStripPlacement" Value="Bottom">
                <Setter TargetName="HeaderPanel" Property="Grid.Row" Value="1"/>
                <Setter TargetName="ContentPanel" Property="Grid.Row" Value="0"/>
                <Setter TargetName="TopRow" Property="Height" Value="*"/>
                <Setter TargetName="BottomRow" Property="Height" Value="Auto"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="HeaderPanel" Property="Opacity" Value="0.6"/>
                <Setter TargetName="ContentPanel" Property="Opacity" Value="0.6"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate TargetType="TabControl" x:Key="md.sys.TabControl.ControlTemplate.Filled">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TopRow" Height="Auto"/>
                <RowDefinition x:Name="BottomRow" Height="*"/>
            </Grid.RowDefinitions>
            <TabPanel x:Name="HeaderPanel" Grid.Row="0" Margin="4" IsItemsHost="True" Panel.ZIndex="1" HorizontalAlignment="Center">
            </TabPanel>
            <Border x:Name="ContentPanel" Grid.Row="1" Style="{DynamicResource FilledCard}" Background="{TemplateBinding Background}">
                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}"/>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="TabStripPlacement" Value="Bottom">
                <Setter TargetName="HeaderPanel" Property="Grid.Row" Value="1"/>
                <Setter TargetName="ContentPanel" Property="Grid.Row" Value="0"/>
                <Setter TargetName="TopRow" Property="Height" Value="*"/>
                <Setter TargetName="BottomRow" Property="Height" Value="Auto"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="HeaderPanel" Property="Opacity" Value="0.6"/>
                <Setter TargetName="ContentPanel" Property="Opacity" Value="0.6"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate TargetType="TabControl" x:Key="md.sys.TabControl.ControlTemplate">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TopRow" Height="Auto"/>
                <RowDefinition x:Name="BottomRow" Height="*"/>
            </Grid.RowDefinitions>
            <TabPanel x:Name="HeaderPanel" Grid.Row="0" Margin="4" IsItemsHost="True" Panel.ZIndex="1" HorizontalAlignment="Center">
            </TabPanel>
            <Border x:Name="ContentPanel" Grid.Row="1" Style="{DynamicResource OutlinedCard}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}">
                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" Margin="{TemplateBinding Padding}"/>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="TabStripPlacement" Value="Bottom">
                <Setter TargetName="HeaderPanel" Property="Grid.Row" Value="1"/>
                <Setter TargetName="ContentPanel" Property="Grid.Row" Value="0"/>
                <Setter TargetName="TopRow" Property="Height" Value="*"/>
                <Setter TargetName="BottomRow" Property="Height" Value="Auto"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="HeaderPanel" Property="Opacity" Value="0.6"/>
                <Setter TargetName="ContentPanel" Property="Opacity" Value="0.6"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate TargetType="TabItem" x:Key="md.sys.TabItem.ControlTemplate">
        <Grid Margin="-1 0">
            <Border x:Name="StateLayer" Background="{DynamicResource 80Brush}" Opacity="0">
                <Border.CornerRadius>
                    <MultiBinding Converter="{cnv:TabIndexConverter}">
                        <Binding RelativeSource="{RelativeSource TemplatedParent}"/>
                        <Binding RelativeSource="{RelativeSource AncestorType=TabControl}"/>
                    </MultiBinding>
                </Border.CornerRadius>
            </Border>
            <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Padding="4 0">
                <Border.CornerRadius>
                    <MultiBinding Converter="{cnv:TabIndexConverter}">
                        <Binding RelativeSource="{RelativeSource TemplatedParent}"/>
                        <Binding RelativeSource="{RelativeSource AncestorType=TabControl}"/>
                    </MultiBinding>
                </Border.CornerRadius>
                <ContentPresenter x:Name="ContentPresenter" Content="{TemplateBinding Header}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10 4"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                  ContentStringFormat="{TemplateBinding ContentStringFormat}">
                    <ContentPresenter.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{Binding FontFamily, RelativeSource={RelativeSource AncestorType=TabControl}}"/>
                            <Setter Property="FontSize" Value="{Binding FontSize, RelativeSource={RelativeSource AncestorType=TabControl}}"/>
                            <Setter Property="FontStretch" Value="{Binding FontStretch, RelativeSource={RelativeSource AncestorType=TabControl}}"/>
                            <Setter Property="FontStyle" Value="{Binding FontStyle, RelativeSource={RelativeSource AncestorType=TabControl}}"/>
                            <Setter Property="FontWeight" Value="{Binding FontWeight, RelativeSource={RelativeSource AncestorType=TabControl}}"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                        </Style>
                    </ContentPresenter.Resources>
                </ContentPresenter>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <!-- Hover -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="StateLayer" Property="Opacity" Value="0.08"/>
            </Trigger>
            <!-- Disabled -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.38"/>
                <Setter TargetName="StateLayer" Property="Opacity" Value="0"/>
            </Trigger>

            <!-- Selected -->
            <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=TabControl}}"/>
                <Setter Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource AncestorType=TabControl}}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="md.TabItem" TargetType="TabItem">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Foreground" Value="{DynamicResource onSurfaceVariantBrush}"/>
        <Setter Property="Background" Value="{DynamicResource surfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource outlineBrush}"/>
        <Setter Property="Template" Value="{StaticResource md.sys.TabItem.ControlTemplate}"/>
    </Style>

    <Style x:Key="md.TabControl.Elevated" TargetType="TabControl">
        <Setter Property="AlternationCount" Value="1000"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource surfaceContainerBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource primaryBrush}"/>
        <Setter Property="Tag" Value="{DynamicResource onPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Template" Value="{StaticResource md.sys.TabControl.ControlTemplate.Elevated}"/>
        <Style.Resources>
            <Style TargetType="TabItem" BasedOn="{StaticResource md.TabItem}"/>
        </Style.Resources>
    </Style>

    <Style x:Key="md.TabControl.Filled" TargetType="TabControl">
        <Setter Property="AlternationCount" Value="1000"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource surfaceContainerBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource primaryBrush}"/>
        <Setter Property="Tag" Value="{DynamicResource onPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Template" Value="{StaticResource md.sys.TabControl.ControlTemplate.Filled}"/>
        <Style.Resources>
            <Style TargetType="TabItem" BasedOn="{StaticResource md.TabItem}"/>
        </Style.Resources>
    </Style>

    <Style x:Key="md.TabControl" TargetType="TabControl">
        <Setter Property="AlternationCount" Value="1000"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="FontFamily" Value="{DynamicResource md.ref.typeface.plain}"/>
        <Setter Property="FontSize" Value="{DynamicResource md.sys.typescale.label-medium-size}"/>
        <Setter Property="FontWeight" Value="{DynamicResource md.sys.typescale.label-medium-weight}"/>
        <Setter Property="Background" Value="{DynamicResource surfaceContainerBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource primaryBrush}"/>
        <Setter Property="Tag" Value="{DynamicResource onPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Template" Value="{StaticResource md.sys.TabControl.ControlTemplate}"/>
        <Style.Resources>
            <Style TargetType="TabItem" BasedOn="{StaticResource md.TabItem}"/>
        </Style.Resources>
    </Style>

</ResourceDictionary>