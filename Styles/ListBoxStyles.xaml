<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:cnv="clr-namespace:DariuszLabaj.MaterialIo461.Converters">
    <ControlTemplate x:Key="md.sys.ListBoxItem.ControlTemplate" TargetType="ListBoxItem">
        <Grid Margin="0 0 0 -1">
            <Border x:Name="StateLayer" Background="{DynamicResource 80Brush}" Opacity="0">
                <Border.CornerRadius>
                    <MultiBinding Converter="{cnv:ListIndexConverter}">
                        <Binding RelativeSource="{RelativeSource TemplatedParent}"/>
                        <Binding RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                    </MultiBinding>
                </Border.CornerRadius>
            </Border>
            <Border x:Name="Highlight" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBox}}" Opacity="0">
                <Border.CornerRadius>
                    <MultiBinding Converter="{cnv:ListIndexConverter}">
                        <Binding RelativeSource="{RelativeSource TemplatedParent}"/>
                        <Binding RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                    </MultiBinding>
                </Border.CornerRadius>
            </Border>
            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                <Border.CornerRadius>
                    <MultiBinding Converter="{cnv:ListIndexConverter}">
                        <Binding RelativeSource="{RelativeSource TemplatedParent}"/>
                        <Binding RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                    </MultiBinding>
                </Border.CornerRadius>
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                    <ContentPresenter.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{Binding FontFamily, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                            <Setter Property="FontSize" Value="{Binding FontSize, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                            <Setter Property="FontStretch" Value="{Binding FontStretch, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                            <Setter Property="FontStyle" Value="{Binding FontStyle, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                            <Setter Property="FontWeight" Value="{Binding FontWeight, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                            <Setter Property="Foreground" Value="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                        </Style>
                    </ContentPresenter.Resources>
                </ContentPresenter>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <!-- Hover -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Highlight" Property="Opacity" Value="0.25"/>
            </Trigger>
            <!-- Disabled -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.38"/>
                <Setter TargetName="StateLayer" Property="Opacity" Value="0"/>
            </Trigger>
            <!-- Selected Inactive -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="Selector.IsSelectionActive" Value="False"/>
                    <Condition Property="IsSelected" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Highlight" Property="Opacity" Value="0.5"/>
            </MultiTrigger>
            <!-- Selected Active -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="Selector.IsSelectionActive" Value="True"/>
                    <Condition Property="IsSelected" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter TargetName="Highlight" Property="Opacity" Value="0.5"/>
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="TextElement.Foreground" TargetName="Bd" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>
    <ControlTemplate x:Key="md.sys.ListBox.ControlTemplate" TargetType="ListBox">
        <Grid>
            <Border x:Name="StateLayer" Background="{DynamicResource 80Brush}" CornerRadius="8" Opacity="0"/>
            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="true">
                <ScrollViewer Focusable="false" Padding="{TemplateBinding Padding}" Style="{DynamicResource md.ScrollViewer}">
                    <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" Margin="0 0 0 1"/>
                </ScrollViewer>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <!-- Disabled -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.38"/>
                <Setter TargetName="StateLayer" Property="Opacity" Value="0"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsGrouping" Value="true"/>
                    <Condition Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="false"/>
                </MultiTrigger.Conditions>
                <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
            </MultiTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>
    <Style x:Key="md.ListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Template" Value="{StaticResource md.sys.ListBoxItem.ControlTemplate}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
    <Style x:Key="md.ListBox" TargetType="ListBox">
        <Setter Property="AlternationCount" Value="1000"/>
        <Setter Property="Template" Value="{StaticResource md.sys.ListBox.ControlTemplate}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource surfaceBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="ItemContainerStyle" Value="{DynamicResource md.ListBoxItem}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FontFamily" Value="{DynamicResource md.ref.typeface.plain}"/>
        <Setter Property="FontSize" Value="{DynamicResource md.sys.typescale.body-medium-size}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource primaryContainerBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource primaryBrush}"/>
        <Setter Property="Margin" Value="4"/>
    </Style>
</ResourceDictionary>