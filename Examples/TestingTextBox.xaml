<Page x:Class="DariuszLabaj.MaterialIo461.Examples.TestingTextBox"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DariuszLabaj.MaterialIo461.Examples"
      xmlns:conv="clr-namespace:DariuszLabaj.MaterialIo461.Converters"
      xmlns:mt="clr-namespace:DariuszLabaj.MaterialIo461.CustomUserControl"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TestingTextBox"
      Background="MediumPurple">
    <StackPanel HorizontalAlignment="Center">
        <TextBox Width="100" Height="Auto" Padding="2 0"
                 mt:TextBoxHelper.Label="Test"/>
        <TextBox Width="100" Height="Auto" Padding="2 0"
                mt:TextBoxHelper.Label="Test" Tag="Supporting Text"/>
        <TextBox Width="100" Height="Auto" Padding="2 0"
                mt:TextBoxHelper.Label="Test"/>
    </StackPanel>
</Page>
